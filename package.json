{
  "name": "gennews-post",
  "version": "1.0.0",
  "description": "AI news blog post generator for GitHub Pages",
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-post.mjs",
    "test:fetch": "node scripts/generate-post.mjs --fetch-only",
